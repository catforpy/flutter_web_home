  /// 获取筛选后的课程列表
  List<Course> get _filteredCourses {
    var courses = _courses;

    // 按讲师筛选
    if (_selectedInstructorId != null) {
      courses = courses
          .where((course) => course.instructorId == _selectedInstructorId)
          .toList();
    }

    // 按行业分类筛选
    if (_selectedIndustryCategoryId != null) {
      courses = courses
          .where((course) =>
              course.industryCategoryId == _selectedIndustryCategoryId)
          .toList();
    }

    // 按形式分类筛选
    if (_selectedFormatCategoryId != null) {
      courses = courses
          .where((course) =>
              course.formatCategoryId == _selectedFormatCategoryId)
          .toList();
    }

    // 按类型分类筛选
    if (_selectedTypeCategoryId != null) {
      courses = courses
          .where((course) => course.typeCategoryId == _selectedTypeCategoryId)
          .toList();
    }

    // 按关键词搜索
    if (_searchKeyword.isNotEmpty) {
      courses = courses
          .where((course) =>
              course.title
                  .toLowerCase()
                  .contains(_searchKeyword.toLowerCase()) ||
              course.instructorName
                  .toLowerCase()
                  .contains(_searchKeyword.toLowerCase()))
          .toList();
    }

    return courses;
  }

  @override
  Widget build(BuildContext context) {
    final filteredCourses = _filteredCourses;

    return Column(
      children: [
        _buildHeader(),
        _buildFilters(),
        Expanded(
          child: _buildCourseList(filteredCourses),
        ),
        _buildPagination(filteredCourses.length),
      ],
    );
  }

  /// 构建标题栏
  Widget _buildHeader() {
    return Container(
      padding: const EdgeInsets.all(16),
      decoration: BoxDecoration(
        color: Colors.white,
        boxShadow: [
          BoxShadow(
            color: Colors.grey.withOpacity(0.1),
            spreadRadius: 1,
            blurRadius: 3,
          ),
        ],
      ),
      child: const Row(
        children: [
          Text(
            '课程列表',
            style: TextStyle(
              fontSize: 20,
              fontWeight: FontWeight.bold,
            ),
          ),
        ],
      ),
    );
  }

